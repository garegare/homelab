# .env file for Homelab services

# Local IP Address of the server running Docker
LOCAL_IP_ADDRESS=192.168.1.10

# Hostnames for services, to be used with Nginx Proxy Manager

# n8n
N8N_HOSTNAME=n8n.local # You can use a local DNS entry or just the IP

# Open WebUI (placeholder, will be configured later)
OPEN_WEBUI_HOSTNAME=open-webui.local

# Database credentials
POSTGRES_USER=homelab_user
POSTGRES_PASSWORD=homelab_password
POSTGRES_DB=postgres
N8N_DB_NAME=n8n
DB_POSTGRESDB_PASSWORD=homelab_password
OPEN_WEBUI_DB_NAME=open-webui
